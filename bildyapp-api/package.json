{
  "name": "bildyapp-api",
  "version": "1.0.0",
  "description": "Backend API for construction project management",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
